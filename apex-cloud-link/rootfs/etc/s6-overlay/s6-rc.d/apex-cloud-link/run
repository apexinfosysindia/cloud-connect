#!/usr/bin/with-contenv bashio
set -e

FRP_VERSION="0.56.0"
FRP_SERVER_ADDR="cloud.apexinfosys.in"
FRP_SERVER_PORT=7000
CLOUD_API_URL="https://cloud.apexinfosys.in"
HA_API_BASE_URL="http://supervisor/core/api"
FRP_DIR="/data/frp"
FRPC_BIN="${FRP_DIR}/frpc"
FRPC_CONFIG="/tmp/frpc.toml"
DEVICE_TOKEN_PATH="/data/cloud_device_token"
DEVICE_SSH_REMOTE_PORT_PATH="/data/cloud_device_ssh_remote_port"

HEARTBEAT_INTERVAL=20
HEARTBEAT_PID=""
DEVICE_TOKEN=""
SSH_REMOTE_PORT=0
SSH_LOCAL_PORT=22
GOOGLE_ENTITY_SYNC_INTERVAL=5
GOOGLE_COMMAND_SYNC_INTERVAL=1
ALEXA_COMMAND_SYNC_INTERVAL=1
GOOGLE_SYNC_PID=""
GOOGLE_WARNED_NO_SUPERVISOR_TOKEN=0
GOOGLE_WARNED_STATE_FETCH=0
GOOGLE_WARNED_EMPTY_ENTITY_SYNC=0
GOOGLE_ENTITY_SYNC_PAGE_LIMIT=300
GOOGLE_ENTITY_SYNC_BATCH_SIZE=120
CLOUD_POST_STATUS=""
CLOUD_POST_BODY=""

SUBDOMAIN=$(bashio::config 'subdomain')
ACCESS_TOKEN=$(bashio::config 'access_token')

SUBDOMAIN=${SUBDOMAIN//.cloud.apexinfosys.in/}

sanitize_uid() {
    printf '%s' "$1" | tr -cd 'a-zA-Z0-9._-'
}

is_valid_port() {
    case "$1" in
        ''|*[!0-9]*)
            return 1
            ;;
    esac

    if [ "$1" -lt 1 ] || [ "$1" -gt 65535 ]; then
        return 1
    fi

    return 0
}

get_local_ips_csv() {
    local ip_list=''

    if command -v ip >/dev/null 2>&1; then
        ip_list=$(ip -o -4 addr show scope global 2>/dev/null | awk '{split($4, parts, "/"); print parts[1]}' | paste -sd, -)
    fi

    if [ -z "$ip_list" ] && command -v hostname >/dev/null 2>&1; then
        ip_list=$(hostname -i 2>/dev/null | tr ' ' ',' | sed 's/,$//')
    fi

    printf '%s' "$ip_list"
}

cloud_post() {
    local endpoint="$1"
    local payload="$2"
    local token="$3"
    local base_url="${CLOUD_API_URL%/}"
    local url="${base_url}${endpoint}"

    if [ -z "$token" ]; then
        curl -fsS --max-time 12 \
            -H "Content-Type: application/json" \
            -X POST "$url" \
            -d "$payload" 2>/dev/null || true
        return
    fi

    curl -fsS --max-time 12 \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer ${token}" \
        -X POST "$url" \
        -d "$payload" 2>/dev/null || true
}

cloud_post_capture() {
    local endpoint="$1"
    local payload="$2"
    local token="$3"
    local base_url="${CLOUD_API_URL%/}"
    local url="${base_url}${endpoint}"
    local response=''

    if [ -z "$token" ]; then
        response=$(curl -sS --max-time 20 \
            -H "Content-Type: application/json" \
            -X POST "$url" \
            -d "$payload" \
            -w $'\n%{http_code}' 2>/dev/null || true)
    else
        response=$(curl -sS --max-time 20 \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer ${token}" \
            -X POST "$url" \
            -d "$payload" \
            -w $'\n%{http_code}' 2>/dev/null || true)
    fi

    CLOUD_POST_STATUS="${response##*$'\n'}"
    if [ "$CLOUD_POST_STATUS" = "$response" ]; then
        CLOUD_POST_STATUS="000"
        CLOUD_POST_BODY=''
        return
    fi

    CLOUD_POST_BODY="${response%$'\n'*}"
}

ha_api_get() {
    local endpoint="$1"
    local url="${HA_API_BASE_URL}${endpoint}"

    if [ -z "${SUPERVISOR_TOKEN:-}" ]; then
        if [ "$GOOGLE_WARNED_NO_SUPERVISOR_TOKEN" -eq 0 ]; then
            bashio::log.warning "Google sync disabled: SUPERVISOR_TOKEN unavailable. Ensure addon has required API permissions."
            GOOGLE_WARNED_NO_SUPERVISOR_TOKEN=1
        fi
        return
    fi

    curl -fsS --max-time 12 \
        -H "Authorization: Bearer ${SUPERVISOR_TOKEN}" \
        -H "Content-Type: application/json" \
        "$url" 2>/dev/null || true
}

ha_api_post() {
    local endpoint="$1"
    local payload="$2"
    local url="${HA_API_BASE_URL}${endpoint}"

    if [ -z "${SUPERVISOR_TOKEN:-}" ]; then
        if [ "$GOOGLE_WARNED_NO_SUPERVISOR_TOKEN" -eq 0 ]; then
            bashio::log.warning "Google command execution disabled: SUPERVISOR_TOKEN unavailable."
            GOOGLE_WARNED_NO_SUPERVISOR_TOKEN=1
        fi
        return
    fi

    curl -fsS --max-time 12 \
        -H "Authorization: Bearer ${SUPERVISOR_TOKEN}" \
        -H "Content-Type: application/json" \
        -X POST "$url" \
        -d "$payload" 2>/dev/null || true
}

sync_google_entities() {
    if [ "$FLEET_ACTIVE" -ne 1 ] || [ -z "$DEVICE_TOKEN" ]; then
        return
    fi

    local states_json
    states_json=$(ha_api_get "/states")
    if [ -z "$states_json" ]; then
        if [ "$GOOGLE_WARNED_STATE_FETCH" -eq 0 ]; then
            bashio::log.warning "Google entity sync skipped: unable to fetch states from Supervisor API"
            GOOGLE_WARNED_STATE_FETCH=1
        fi
        return
    fi

    GOOGLE_WARNED_STATE_FETCH=0

    # Fetch entity + device + area registries via WebSocket API for device info and room hints
    # (REST endpoints /api/config/entity_registry and /api/config/device_registry do not exist;
    #  these are WebSocket-only APIs: config/entity_registry/list, config/device_registry/list,
    #  config/area_registry/list)
    local device_info_map='{}'
    local area_map='{}'
    if [ -n "${SUPERVISOR_TOKEN:-}" ]; then
        local ws_result
        ws_result=$(python3 -c "
import json, os, sys
try:
    from websocket import create_connection
    token = os.environ.get('SUPERVISOR_TOKEN', '')
    ws = create_connection('ws://supervisor/core/websocket', timeout=8)
    msg = json.loads(ws.recv())
    if msg.get('type') == 'auth_required':
        ws.send(json.dumps({'type': 'auth', 'access_token': token}))
    msg = json.loads(ws.recv())
    if msg.get('type') != 'auth_ok':
        ws.close()
        print(json.dumps({'device_info': {}, 'areas': {}}))
        sys.exit(0)
    # Fetch entity registry
    ws.send(json.dumps({'id': 1, 'type': 'config/entity_registry/list'}))
    ent_resp = json.loads(ws.recv())
    # Fetch device registry
    ws.send(json.dumps({'id': 2, 'type': 'config/device_registry/list'}))
    dev_resp = json.loads(ws.recv())
    # Fetch area registry
    ws.send(json.dumps({'id': 3, 'type': 'config/area_registry/list'}))
    area_resp = json.loads(ws.recv())
    ws.close()
    entities = ent_resp.get('result', []) if ent_resp.get('success') else []
    devices = dev_resp.get('result', []) if dev_resp.get('success') else []
    areas = area_resp.get('result', []) if area_resp.get('success') else []
    # Build area_id -> area_name lookup
    area_name_map = {}
    for a in areas:
        aid = a.get('area_id', '')
        aname = a.get('name', '')
        if aid and aname:
            area_name_map[aid] = aname
    # Build device_id -> {manufacturer, model, sw_version, area_id} lookup
    dev_map = {}
    for d in devices:
        did = d.get('id', '')
        if did:
            dev_map[did] = {
                'manufacturer': d.get('manufacturer') or None,
                'model': d.get('model') or None,
                'sw_version': d.get('sw_version') or None,
                'area_id': d.get('area_id') or None
            }
    # Build entity_id -> device info map and entity_id -> area_name map
    dev_result = {}
    area_result = {}
    for e in entities:
        eid = e.get('entity_id', '')
        did = e.get('device_id', '')
        # Device info
        if eid and did and did in dev_map:
            dev_result[eid] = {
                'manufacturer': dev_map[did]['manufacturer'],
                'model': dev_map[did]['model'],
                'sw_version': dev_map[did]['sw_version']
            }
        # Area: entity's own area_id takes priority, then device's area_id
        if eid:
            ent_area = e.get('area_id') or None
            dev_area = dev_map.get(did, {}).get('area_id') if did else None
            resolved_area = ent_area or dev_area
            if resolved_area and resolved_area in area_name_map:
                area_result[eid] = area_name_map[resolved_area]
    print(json.dumps({'device_info': dev_result, 'areas': area_result}))
except Exception:
    print(json.dumps({'device_info': {}, 'areas': {}}))
" 2>/dev/null) || ws_result='{"device_info":{},"areas":{}}'

        # Parse the combined result
        device_info_map=$(printf '%s' "$ws_result" | jq -c '.device_info // {}' 2>/dev/null) || device_info_map='{}'
        area_map=$(printf '%s' "$ws_result" | jq -c '.areas // {}' 2>/dev/null) || area_map='{}'
    fi

    # Safety: ensure device_info_map and area_map are valid JSON objects
    if ! printf '%s' "$device_info_map" | jq -e 'type == "object"' >/dev/null 2>&1; then
        device_info_map='{}'
    fi
    if ! printf '%s' "$area_map" | jq -e 'type == "object"' >/dev/null 2>&1; then
        area_map='{}'
    fi

    local entities_json='[]'
    entities_json=$(printf '%s' "$states_json" | jq -c --argjson devinfo "$device_info_map" --argjson areamap "$area_map" '
            map(select(.entity_id | test("^(switch|light|sensor|fan|cover|lock|climate|media_player|scene|button|vacuum|humidifier|alarm_control_panel|water_heater|binary_sensor|input_boolean|automation|script|camera|group|input_button|input_select|select|valve|lawn_mower|event)\\.")))
            | map(select(
                if (.entity_id | startswith("sensor."))
                then (
                    ((.attributes.device_class // "") | tostring) | test("^(temperature|humidity|pm25|pm10|carbon_dioxide|carbon_monoxide|volatile_organic_compounds|aqi)$")
                ) or (
                    ((.attributes.unit_of_measurement // "") | tostring) | test("^(°C|°F|C|F)$")
                )
                elif (.entity_id | startswith("binary_sensor."))
                then (
                    ((.attributes.device_class // "") | tostring) | test("^(door|window|garage_door|opening|motion|occupancy|smoke|moisture|co|carbon_monoxide|gas)$")
                )
                elif (.entity_id | startswith("event."))
                then (
                    ((.attributes.device_class // "") | tostring) | test("^(doorbell)$")
                )
                else true
                end
            ))
            | map(
                . as $s
                | (($s.state // "") | tostring | ascii_downcase) as $state_text
                | ($s.attributes.supported_features // 0) as $sf
                | ($s.attributes.device_class // null) as $dc
                | {
                    entity_id: $s.entity_id,
                    display_name: ($s.attributes.friendly_name // $s.entity_id),
                    room_hint: ($areamap[$s.entity_id] // ""),
                    online: (
                        if ($s.entity_id | (startswith("scene.") or startswith("script.") or startswith("button.") or startswith("input_button.")))
                        then true
                        else ($state_text != "unavailable")
                        end
                    ),
                    entity_type: (
                        if ($s.entity_id | startswith("light.")) then "light"
                        elif ($s.entity_id | startswith("fan.")) then "fan"
                        elif ($s.entity_id | startswith("cover.")) then "cover"
                        elif ($s.entity_id | startswith("lock.")) then "lock"
                        elif ($s.entity_id | startswith("climate.")) then "climate"
                        elif ($s.entity_id | startswith("media_player.")) then "media_player"
                        elif ($s.entity_id | startswith("scene.")) then "scene"
                        elif ($s.entity_id | startswith("button.")) then "button"
                        elif ($s.entity_id | startswith("vacuum.")) then "vacuum"
                        elif ($s.entity_id | startswith("humidifier.")) then "humidifier"
                        elif ($s.entity_id | startswith("alarm_control_panel.")) then "alarm_control_panel"
                        elif ($s.entity_id | startswith("water_heater.")) then "water_heater"
                        elif ($s.entity_id | startswith("binary_sensor.")) then "binary_sensor"
                        elif ($s.entity_id | startswith("sensor.")) then "sensor"
                        elif ($s.entity_id | startswith("automation.")) then "automation"
                        elif ($s.entity_id | startswith("script.")) then "script"
                        elif ($s.entity_id | startswith("camera.")) then "camera"
                        elif ($s.entity_id | startswith("group.")) then "group"
                        elif ($s.entity_id | startswith("input_button.")) then "input_button"
                        elif ($s.entity_id | startswith("input_select.")) then "input_select"
                        elif ($s.entity_id | startswith("select.")) then "select"
                        elif ($s.entity_id | startswith("valve.")) then "valve"
                        elif ($s.entity_id | startswith("lawn_mower.")) then "lawn_mower"
                        elif ($s.entity_id | startswith("event.")) then "event"
                        else "switch"
                        end
                    ),
                    state: (
                        if ($s.entity_id | startswith("light.")) then {
                            on: ($s.state == "on"),
                            brightness: (((($s.attributes.brightness | tonumber?) // 0) * 100 / 255) | floor),
                            color_mode: ($s.attributes.color_mode // null),
                            color_temp_kelvin: ($s.attributes.color_temp_kelvin // null),
                            hs_color: ($s.attributes.hs_color // null),
                            rgb_color: ($s.attributes.rgb_color // null),
                            effect: ($s.attributes.effect // null),
                            supported_features: $sf,
                            supported_color_modes: ($s.attributes.supported_color_modes // []),
                            min_color_temp_kelvin: ($s.attributes.min_color_temp_kelvin // null),
                            max_color_temp_kelvin: ($s.attributes.max_color_temp_kelvin // null),
                            effect_list: ($s.attributes.effect_list // [])
                        }
                        elif ($s.entity_id | startswith("fan.")) then {
                            on: ($s.state == "on"),
                            percentage: (($s.attributes.percentage | tonumber?) // 0),
                            preset_mode: ($s.attributes.preset_mode // null),
                            oscillating: (($s.attributes.oscillating // false) == true),
                            direction: ($s.attributes.direction // null),
                            supported_features: $sf,
                            percentage_step: ($s.attributes.percentage_step // null),
                            preset_modes: ($s.attributes.preset_modes // []),
                            speed: (((($s.attributes.percentage | tonumber?) // 0) / 33.33) | ceil)
                        }
                        elif ($s.entity_id | startswith("cover.")) then {
                            openPercent: (($s.attributes.current_position | tonumber?) // (if $state_text == "open" then 100 elif $state_text == "closed" then 0 else 50 end)),
                            tilt_position: ($s.attributes.current_tilt_position // null),
                            supported_features: $sf,
                            device_class: $dc
                        }
                        elif ($s.entity_id | startswith("lock.")) then {
                            isLocked: ($s.state == "locked"),
                            supported_features: $sf
                        }
                        elif ($s.entity_id | startswith("climate.")) then {
                            mode: ($s.state // "off"),
                            hvac_modes: ($s.attributes.hvac_modes // []),
                            preset_mode: ($s.attributes.preset_mode // null),
                            preset_modes: ($s.attributes.preset_modes // []),
                            fan_mode: ($s.attributes.fan_mode // null),
                            fan_modes: ($s.attributes.fan_modes // []),
                            swing_mode: ($s.attributes.swing_mode // null),
                            swing_modes: ($s.attributes.swing_modes // []),
                            target_temperature: (($s.attributes.temperature | tonumber?) // null),
                            target_temp_low: (($s.attributes.target_temp_low | tonumber?) // null),
                            target_temp_high: (($s.attributes.target_temp_high | tonumber?) // null),
                            ambient_temperature: (($s.attributes.current_temperature | tonumber?) // null),
                            current_humidity: (($s.attributes.current_humidity | tonumber?) // null),
                            target_humidity: (($s.attributes.target_humidity | tonumber?) // null),
                            min_temp: (($s.attributes.min_temp | tonumber?) // null),
                            max_temp: (($s.attributes.max_temp | tonumber?) // null),
                            supported_features: $sf,
                            temperature_unit: (if (($s.attributes.temperature_unit // "°C") | tostring | test("F")) then "F" else "C" end)
                        }
                        elif ($s.entity_id | startswith("media_player.")) then {
                            on: (($s.state != "off") and ($s.state != "standby")),
                            volume: (((($s.attributes.volume_level | tonumber?) // 0) * 100) | floor),
                            muted: (($s.attributes.is_volume_muted // false) == true),
                            media_content_type: ($s.attributes.media_content_type // null),
                            media_title: ($s.attributes.media_title // null),
                            media_artist: ($s.attributes.media_artist // null),
                            media_duration: ($s.attributes.media_duration // null),
                            media_position: ($s.attributes.media_position // null),
                            source: ($s.attributes.source // null),
                            source_list: ($s.attributes.source_list // []),
                            sound_mode: ($s.attributes.sound_mode // null),
                            sound_mode_list: ($s.attributes.sound_mode_list // []),
                            supported_features: $sf,
                            device_class: $dc,
                            is_playing: ($s.state == "playing"),
                            is_paused: ($s.state == "paused"),
                            is_idle: ($s.state == "idle")
                        }
                        elif ($s.entity_id | startswith("scene.")) then {
                            activated: false
                        }
                        elif ($s.entity_id | startswith("button.")) then {
                            pressed: false
                        }
                        elif ($s.entity_id | startswith("vacuum.")) then {
                            on: ($s.state != "docked"),
                            isRunning: (($s.state == "cleaning") or ($s.state == "returning")),
                            isPaused: ($s.state == "paused"),
                            isDocked: ($s.state == "docked"),
                            battery_level: (($s.attributes.battery_level | tonumber?) // null),
                            fan_speed: ($s.attributes.fan_speed // null),
                            fan_speed_list: ($s.attributes.fan_speed_list // []),
                            supported_features: $sf,
                            status: ($s.state // "unknown")
                        }
                        elif ($s.entity_id | startswith("humidifier.")) then {
                            on: ($s.state == "on"),
                            mode: ($s.attributes.mode // null),
                            available_modes: ($s.attributes.available_modes // []),
                            target_humidity: (($s.attributes.humidity | tonumber?) // null),
                            current_humidity: (($s.attributes.current_humidity | tonumber?) // null),
                            min_humidity: (($s.attributes.min_humidity | tonumber?) // null),
                            max_humidity: (($s.attributes.max_humidity | tonumber?) // null),
                            supported_features: $sf,
                            device_class: $dc
                        }
                        elif ($s.entity_id | startswith("alarm_control_panel.")) then {
                            arm_state: $state_text,
                            code_format: ($s.attributes.code_format // null),
                            supported_features: $sf
                        }
                        elif ($s.entity_id | startswith("water_heater.")) then {
                            on: (($s.state != "off") and ($state_text != "off")),
                            current_temperature: (($s.attributes.current_temperature | tonumber?) // null),
                            target_temperature: (($s.attributes.temperature | tonumber?) // null),
                            min_temp: (($s.attributes.min_temp | tonumber?) // null),
                            max_temp: (($s.attributes.max_temp | tonumber?) // null),
                            operation_mode: ($s.state // "off"),
                            operation_list: ($s.attributes.operation_list // []),
                            supported_features: $sf,
                            temperature_unit: (if (($s.attributes.temperature_unit // "°C") | tostring | test("F")) then "F" else "C" end)
                        }
                        elif ($s.entity_id | startswith("binary_sensor.")) then {
                            is_on: ($s.state == "on"),
                            device_class: $dc
                        }
                        elif ($s.entity_id | startswith("sensor.")) then {
                            value: (($s.state | tonumber?) // null),
                            device_class: $dc,
                            unit_of_measurement: ($s.attributes.unit_of_measurement // null),
                            temperature: (if (($dc // "") == "temperature") then (($s.state | tonumber?) // 0) else null end)
                        }
                        elif ($s.entity_id | startswith("automation.")) then {
                            on: ($s.state == "on"),
                            supported_features: $sf
                        }
                        elif ($s.entity_id | startswith("script.")) then {
                            activated: false
                        }
                        elif ($s.entity_id | startswith("camera.")) then {
                            is_streaming: ($s.state == "streaming"),
                            supported_features: $sf,
                            device_class: $dc,
                            frontend_stream_type: ($s.attributes.frontend_stream_type // "hls")
                        }
                        elif ($s.entity_id | startswith("group.")) then {
                            on: ($s.state == "on"),
                            supported_features: $sf
                        }
                        elif ($s.entity_id | startswith("input_button.")) then {
                            pressed: false
                        }
                        elif ($s.entity_id | startswith("input_select.")) then {
                            current_option: ($s.state // ""),
                            options: ($s.attributes.options // []),
                            supported_features: $sf
                        }
                        elif ($s.entity_id | startswith("select.")) then {
                            current_option: ($s.state // ""),
                            options: ($s.attributes.options // []),
                            supported_features: $sf
                        }
                        elif ($s.entity_id | startswith("valve.")) then {
                            openPercent: (($s.attributes.current_position | tonumber?) // (if $state_text == "open" then 100 elif $state_text == "closed" then 0 else 50 end)),
                            supported_features: $sf,
                            device_class: $dc
                        }
                        elif ($s.entity_id | startswith("lawn_mower.")) then {
                            isRunning: ($s.state == "mowing"),
                            isPaused: ($s.state == "paused"),
                            isDocked: ($s.state == "docked"),
                            supported_features: $sf
                        }
                        elif ($s.entity_id | startswith("event.")) then {
                            device_class: $dc,
                            event_type: ($s.attributes.event_type // null)
                        }
                        else {
                            on: ($s.state == "on"),
                            supported_features: $sf
                        }
                        end
                    ),
                    manufacturer: (($devinfo[$s.entity_id].manufacturer // null) | if . == "" then null else . end),
                    model: (($devinfo[$s.entity_id].model // null) | if . == "" then null else . end),
                    sw_version: (($devinfo[$s.entity_id].sw_version // null) | if . == "" then null else . end)
                }
            )
        ' 2>/tmp/google_entity_jq_err || { bashio::log.warning "Google entity jq pipeline failed: $(cat /tmp/google_entity_jq_err 2>/dev/null | head -1)"; printf '[]'; })

    local entities_count
    entities_count=$(printf '%s' "$entities_json" | jq -r 'length' 2>/dev/null || printf '0')
    if [ "$entities_count" -eq 0 ]; then
        if [ "$GOOGLE_WARNED_EMPTY_ENTITY_SYNC" -eq 0 ]; then
            bashio::log.warning "Google entity sync produced zero entities. Check states and addon API permissions."
            GOOGLE_WARNED_EMPTY_ENTITY_SYNC=1
        fi
        return
    else
        GOOGLE_WARNED_EMPTY_ENTITY_SYNC=0
    fi

    local all_entity_ids_json='[]'
    all_entity_ids_json=$(printf '%s' "$entities_json" | jq -c 'map(.entity_id)' 2>/dev/null || printf '[]')

    local offset=0
    local chunk='[]'
    local payload
    while true; do
        chunk=$(printf '%s' "$entities_json" | jq -c --argjson offset "$offset" --argjson limit "$GOOGLE_ENTITY_SYNC_BATCH_SIZE" '.[$offset:($offset + $limit)]' 2>/dev/null || printf '[]')
        if [ -z "$chunk" ] || [ "$chunk" = "[]" ]; then
            break
        fi

        payload=$(jq -n --argjson entities "$chunk" '{entities: $entities, full_snapshot: false}')
        cloud_post_capture "/api/internal/devices/google-home/entities" "$payload" "$DEVICE_TOKEN"

        case "$CLOUD_POST_STATUS" in
            2??)
                ;;
            502|503|504|000)
                # Transient error — retry once after 3s backoff
                bashio::log.warning "Google entity sync batch got transient status=${CLOUD_POST_STATUS}, retrying in 3s..."
                sleep 3
                cloud_post_capture "/api/internal/devices/google-home/entities" "$payload" "$DEVICE_TOKEN"
                case "$CLOUD_POST_STATUS" in
                    2??)
                        ;;
                    *)
                        bashio::log.warning "Google entity sync batch retry failed with status=${CLOUD_POST_STATUS} body=${CLOUD_POST_BODY}"
                        return
                        ;;
                esac
                ;;
            *)
                bashio::log.warning "Google entity sync batch failed with status=${CLOUD_POST_STATUS} body=${CLOUD_POST_BODY}"
                return
                ;;
        esac

        offset=$((offset + GOOGLE_ENTITY_SYNC_BATCH_SIZE))
    done

    payload=$(jq -n --argjson entities '[]' --argjson snapshot_entity_ids "$all_entity_ids_json" '{entities: $entities, full_snapshot: true, snapshot_entity_ids: $snapshot_entity_ids}')
    cloud_post_capture "/api/internal/devices/google-home/entities" "$payload" "$DEVICE_TOKEN"
    case "$CLOUD_POST_STATUS" in
        2??)
            ;;
        502|503|504|000)
            bashio::log.warning "Google entity sync snapshot commit got transient status=${CLOUD_POST_STATUS}, retrying in 3s..."
            sleep 3
            cloud_post_capture "/api/internal/devices/google-home/entities" "$payload" "$DEVICE_TOKEN"
            case "$CLOUD_POST_STATUS" in
                2??)
                    ;;
                *)
                    bashio::log.warning "Google entity sync snapshot commit retry failed with status=${CLOUD_POST_STATUS} body=${CLOUD_POST_BODY}"
                    return
                    ;;
            esac
            ;;
        *)
            bashio::log.warning "Google entity sync snapshot commit failed with status=${CLOUD_POST_STATUS} body=${CLOUD_POST_BODY}"
            return
            ;;
    esac
}

execute_google_command() {
    # Channel-aware command dispatcher.
    #
    # Historically this function was Google-only and POSTed to
    # /api/internal/devices/google-home/commands/:id/result. To support Alexa
    # without duplicating the entire HA-service case-switch, we accept an
    # optional second positional arg ($2) — the "channel" — which selects the
    # result endpoint at the final POST. The HA-side logic is identical for
    # both channels because the server translates Alexa actions into the
    # Google addon dialect (see lib/alexa/addon-action-map.js on the server).
    #
    #   $1 — command JSON item (as emitted by /commands poll)
    #   $2 — "google" (default) or "alexa"
    local command_json="$1"
    local channel="${2:-google}"
    local command_id
    local entity_id
    local action
    local payload_json
    local success=true
    local error_msg=''
    local resulting_state='{}'

    command_id=$(printf '%s' "$command_json" | jq -r '.id // 0' 2>/dev/null) || command_id=0
    entity_id=$(printf '%s' "$command_json" | jq -r '.entity_id // empty' 2>/dev/null) || entity_id=''
    action=$(printf '%s' "$command_json" | jq -r '.action // empty' 2>/dev/null) || action=''
    payload_json=$(printf '%s' "$command_json" | jq -c '.payload // {}' 2>/dev/null) || payload_json='{}'

    # Ensure command_id is numeric for arithmetic comparison
    case "$command_id" in
        ''|*[!0-9]*) command_id=0 ;;
    esac

    if [ -z "$entity_id" ] || [ -z "$action" ] || [ "$command_id" -le 0 ]; then
        return
    fi

    local domain
    domain=${entity_id%%.*}

    if [ "$action" = "set_on" ]; then
        local desired_on
        desired_on=$(printf '%s' "$payload_json" | jq -r '.on // false')
        if [ "$desired_on" = "true" ]; then
            if [ "$domain" = "scene" ]; then
                ha_api_post "/services/scene/turn_on" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            elif [ "$domain" = "script" ]; then
                ha_api_post "/services/script/turn_on" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            elif [ "$domain" = "button" ]; then
                ha_api_post "/services/button/press" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            elif [ "$domain" = "input_button" ]; then
                ha_api_post "/services/input_button/press" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            elif [ "$domain" = "group" ]; then
                ha_api_post "/services/homeassistant/turn_on" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            else
                ha_api_post "/services/${domain}/turn_on" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            fi
            resulting_state='{"on":true}'
        else
            if [ "$domain" = "scene" ] || [ "$domain" = "script" ] || [ "$domain" = "button" ] || [ "$domain" = "input_button" ]; then
                success=true
            elif [ "$domain" = "group" ]; then
                ha_api_post "/services/homeassistant/turn_off" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            else
                ha_api_post "/services/${domain}/turn_off" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            fi
            resulting_state='{"on":false}'
        fi
    elif [ "$action" = "set_brightness" ]; then
        local brightness_percent
        local brightness_255
        brightness_percent=$(printf '%s' "$payload_json" | jq -r '.brightness // 0')
        brightness_255=$(printf '%s' "$brightness_percent" | awk '{v=int($1*255/100); if (v<0) v=0; if (v>255) v=255; print v}')
        ha_api_post "/services/light/turn_on" "$(jq -n --arg entity_id "$entity_id" --argjson brightness "$brightness_255" '{entity_id: $entity_id, brightness: $brightness}')" >/dev/null || success=false
        resulting_state=$(jq -n --argjson brightness "$brightness_percent" '{on: true, brightness: $brightness}')
    elif [ "$action" = "set_color_hs" ]; then
        local hue saturation brightness_255
        hue=$(printf '%s' "$payload_json" | jq -r '.hue // 0')
        saturation=$(printf '%s' "$payload_json" | jq -r '.saturation // 100')
        brightness_255=$(printf '%s' "$payload_json" | jq -r '.brightness_255 // 255')
        ha_api_post "/services/light/turn_on" "$(jq -n --arg entity_id "$entity_id" --argjson hue "$hue" --argjson sat "$saturation" --argjson bri "$brightness_255" '{entity_id: $entity_id, hs_color: [$hue, $sat], brightness: $bri}')" >/dev/null || success=false
        resulting_state=$(jq -n --argjson h "$hue" --argjson s "$saturation" '{on: true, color: {spectrumHsv: {hue: $h, saturation: ($s / 100), value: 1}}}')
    elif [ "$action" = "set_color_temp" ]; then
        local color_temp_kelvin
        color_temp_kelvin=$(printf '%s' "$payload_json" | jq -r '.color_temp_kelvin // 3000')
        ha_api_post "/services/light/turn_on" "$(jq -n --arg entity_id "$entity_id" --argjson kelvin "$color_temp_kelvin" '{entity_id: $entity_id, color_temp_kelvin: $kelvin}')" >/dev/null || success=false
        resulting_state=$(jq -n --argjson kelvin "$color_temp_kelvin" '{on: true, color: {temperatureK: $kelvin}}')
    elif [ "$action" = "set_fan_speed" ]; then
        local fan_speed
        local fan_percentage
        fan_speed=$(printf '%s' "$payload_json" | jq -r '.speed // "1"')
        case "$fan_speed" in
            3|high|HIGH)
                fan_percentage=100
                ;;
            2|medium|MEDIUM)
                fan_percentage=66
                ;;
            *)
                fan_percentage=33
                ;;
        esac
        ha_api_post "/services/fan/turn_on" "$(jq -n --arg entity_id "$entity_id" --argjson percentage "$fan_percentage" '{entity_id: $entity_id, percentage: $percentage}')" >/dev/null || success=false
        resulting_state=$(jq -n --arg speed "${fan_speed}" '{on: true, speed: ($speed|tonumber? // 1)}')
    elif [ "$action" = "set_fan_speed_percent" ]; then
        local fan_percentage
        fan_percentage=$(printf '%s' "$payload_json" | jq -r '.percentage // 0')
        if [ "$fan_percentage" -eq 0 ] 2>/dev/null; then
            ha_api_post "/services/fan/turn_off" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            resulting_state='{"on":false,"percentage":0}'
        else
            ha_api_post "/services/fan/set_percentage" "$(jq -n --arg entity_id "$entity_id" --argjson percentage "$fan_percentage" '{entity_id: $entity_id, percentage: $percentage}')" >/dev/null || success=false
            resulting_state=$(jq -n --argjson pct "$fan_percentage" '{on: true, percentage: $pct}')
        fi
    elif [ "$action" = "set_fan_preset" ]; then
        local preset_mode
        preset_mode=$(printf '%s' "$payload_json" | jq -r '.preset_mode // ""')
        ha_api_post "/services/fan/set_preset_mode" "$(jq -n --arg entity_id "$entity_id" --arg preset_mode "$preset_mode" '{entity_id: $entity_id, preset_mode: $preset_mode}')" >/dev/null || success=false
        resulting_state=$(jq -n --arg pm "$preset_mode" '{on: true, preset_mode: $pm}')
    elif [ "$action" = "set_open_percent" ]; then
        local open_percent
        open_percent=$(printf '%s' "$payload_json" | jq -r '.openPercent // 0')
        if [ "$domain" = "cover" ]; then
            ha_api_post "/services/cover/set_cover_position" "$(jq -n --arg entity_id "$entity_id" --argjson position "$open_percent" '{entity_id: $entity_id, position: $position}')" >/dev/null || success=false
        fi
        resulting_state=$(jq -n --argjson percent "$open_percent" '{openPercent: $percent}')
    elif [ "$action" = "set_open_close" ]; then
        local open_direction
        open_direction=$(printf '%s' "$payload_json" | jq -r '.open // true')
        if [ "$open_direction" = "true" ]; then
            ha_api_post "/services/cover/open_cover" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            resulting_state='{"openPercent":100}'
        else
            ha_api_post "/services/cover/close_cover" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            resulting_state='{"openPercent":0}'
        fi
    elif [ "$action" = "set_tilt" ]; then
        local tilt_percent
        tilt_percent=$(printf '%s' "$payload_json" | jq -r '.tilt // 0')
        ha_api_post "/services/cover/set_cover_tilt_position" "$(jq -n --arg entity_id "$entity_id" --argjson tilt_position "$tilt_percent" '{entity_id: $entity_id, tilt_position: $tilt_position}')" >/dev/null || success=false
        resulting_state=$(jq -n --argjson tilt "$tilt_percent" '{tilt_position: $tilt}')
    elif [ "$action" = "set_lock" ]; then
        local lock_state
        lock_state=$(printf '%s' "$payload_json" | jq -r '.lock // true')
        if [ "$lock_state" = "true" ]; then
            ha_api_post "/services/lock/lock" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            resulting_state='{"isLocked":true}'
        else
            ha_api_post "/services/lock/unlock" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            resulting_state='{"isLocked":false}'
        fi
    elif [ "$action" = "set_thermostat_mode" ]; then
        local hvac_mode
        hvac_mode=$(printf '%s' "$payload_json" | jq -r '.mode // "off"')
        case "$hvac_mode" in
            heatcool)
                hvac_mode="heat_cool"
                ;;
            fan-only)
                hvac_mode="fan_only"
                ;;
        esac
        ha_api_post "/services/climate/set_hvac_mode" "$(jq -n --arg entity_id "$entity_id" --arg hvac_mode "$hvac_mode" '{entity_id: $entity_id, hvac_mode: $hvac_mode}')" >/dev/null || success=false
        resulting_state=$(jq -n --arg mode "$hvac_mode" '{mode: $mode}')
    elif [ "$action" = "set_thermostat_setpoint" ]; then
        local setpoint
        setpoint=$(printf '%s' "$payload_json" | jq -r '.setpoint // 22')
        ha_api_post "/services/climate/set_temperature" "$(jq -n --arg entity_id "$entity_id" --argjson temperature "$setpoint" '{entity_id: $entity_id, temperature: $temperature}')" >/dev/null || success=false
        resulting_state=$(jq -n --argjson target "$setpoint" '{target_temperature: $target}')
    elif [ "$action" = "set_thermostat_setpoint_range" ]; then
        local heat_setpoint cool_setpoint
        heat_setpoint=$(printf '%s' "$payload_json" | jq -r '.heat_setpoint // 20')
        cool_setpoint=$(printf '%s' "$payload_json" | jq -r '.cool_setpoint // 24')
        ha_api_post "/services/climate/set_temperature" "$(jq -n --arg entity_id "$entity_id" --argjson target_temp_low "$heat_setpoint" --argjson target_temp_high "$cool_setpoint" '{entity_id: $entity_id, target_temp_low: $target_temp_low, target_temp_high: $target_temp_high}')" >/dev/null || success=false
        resulting_state=$(jq -n --argjson low "$heat_setpoint" --argjson high "$cool_setpoint" '{target_temp_low: $low, target_temp_high: $high}')
    elif [ "$action" = "set_volume" ]; then
        local volume_percent
        local volume_level
        local muted
        volume_percent=$(printf '%s' "$payload_json" | jq -r '.volume // 0')
        volume_level=$(printf '%s' "$volume_percent" | awk '{v=$1/100; if (v<0) v=0; if (v>1) v=1; print v}')
        ha_api_post "/services/media_player/volume_set" "$(jq -n --arg entity_id "$entity_id" --argjson volume_level "$volume_level" '{entity_id: $entity_id, volume_level: $volume_level}')" >/dev/null || success=false
        if printf '%s' "$payload_json" | jq -e 'has("muted")' >/dev/null 2>&1; then
            muted=$(printf '%s' "$payload_json" | jq -r '.muted // false')
            ha_api_post "/services/media_player/volume_mute" "$(jq -n --arg entity_id "$entity_id" --argjson is_volume_muted "$muted" '{entity_id: $entity_id, is_volume_muted: $is_volume_muted}')" >/dev/null || success=false
            resulting_state=$(jq -n --argjson volume "$volume_percent" --argjson muted "$muted" '{volume: $volume, muted: $muted}')
        else
            resulting_state=$(jq -n --argjson volume "$volume_percent" '{volume: $volume}')
        fi
    elif [ "$action" = "set_mute" ]; then
        local muted
        muted=$(printf '%s' "$payload_json" | jq -r '.muted // false')
        ha_api_post "/services/media_player/volume_mute" "$(jq -n --arg entity_id "$entity_id" --argjson is_volume_muted "$muted" '{entity_id: $entity_id, is_volume_muted: $is_volume_muted}')" >/dev/null || success=false
        resulting_state=$(jq -n --argjson muted "$muted" '{muted: $muted}')
    elif [ "$action" = "media_pause" ]; then
        ha_api_post "/services/media_player/media_pause" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
        resulting_state='{"is_paused":true,"is_playing":false}'
    elif [ "$action" = "media_resume" ]; then
        ha_api_post "/services/media_player/media_play" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
        resulting_state='{"is_paused":false,"is_playing":true}'
    elif [ "$action" = "media_stop" ]; then
        ha_api_post "/services/media_player/media_stop" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
        resulting_state='{"is_paused":false,"is_playing":false}'
    elif [ "$action" = "media_next" ]; then
        ha_api_post "/services/media_player/media_next_track" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
        resulting_state='{}'
    elif [ "$action" = "media_previous" ]; then
        ha_api_post "/services/media_player/media_previous_track" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
        resulting_state='{}'
    elif [ "$action" = "media_seek" ]; then
        local seek_pos
        seek_pos=$(printf '%s' "$payload_json" | jq -r '.seek_position // 0')
        ha_api_post "/services/media_player/media_seek" "$(jq -n --arg entity_id "$entity_id" --argjson pos "$seek_pos" '{entity_id: $entity_id, seek_position: $pos}')" >/dev/null || success=false
        resulting_state='{}'
    elif [ "$action" = "media_seek_relative" ]; then
        local seek_pos
        seek_pos=$(printf '%s' "$payload_json" | jq -r '.seek_position // 0')
        ha_api_post "/services/media_player/media_seek" "$(jq -n --arg entity_id "$entity_id" --argjson pos "$seek_pos" '{entity_id: $entity_id, seek_position: $pos}')" >/dev/null || success=false
        resulting_state='{}'
    elif [ "$action" = "media_shuffle" ]; then
        local shuffle_val
        shuffle_val=$(printf '%s' "$payload_json" | jq -r '.shuffle // false')
        ha_api_post "/services/media_player/shuffle_set" "$(jq -n --arg entity_id "$entity_id" --argjson shuf "$shuffle_val" '{entity_id: $entity_id, shuffle: $shuf}')" >/dev/null || success=false
        resulting_state='{}'
    elif [ "$action" = "media_repeat" ]; then
        local repeat_mode
        repeat_mode=$(printf '%s' "$payload_json" | jq -r '.repeat // "off"')
        ha_api_post "/services/media_player/repeat_set" "$(jq -n --arg entity_id "$entity_id" --arg rep "$repeat_mode" '{entity_id: $entity_id, repeat: $rep}')" >/dev/null || success=false
        resulting_state='{}'
    elif [ "$action" = "set_input" ]; then
        local source_name
        source_name=$(printf '%s' "$payload_json" | jq -r '.source // ""')
        ha_api_post "/services/media_player/select_source" "$(jq -n --arg entity_id "$entity_id" --arg source "$source_name" '{entity_id: $entity_id, source: $source}')" >/dev/null || success=false
        resulting_state=$(jq -n --arg src "$source_name" '{source: $src}')
    elif [ "$action" = "activate_scene" ]; then
        if [ "$domain" = "button" ]; then
            ha_api_post "/services/button/press" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
        elif [ "$domain" = "input_button" ]; then
            ha_api_post "/services/input_button/press" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
        elif [ "$domain" = "script" ]; then
            ha_api_post "/services/script/turn_on" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
        else
            ha_api_post "/services/scene/turn_on" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
        fi
        resulting_state='{"on":true}'
    elif [ "$action" = "set_start_stop" ]; then
        local should_start
        should_start=$(printf '%s' "$payload_json" | jq -r '.start // true')
        if [ "$should_start" = "true" ]; then
            ha_api_post "/services/vacuum/start" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            resulting_state='{"on":true,"isRunning":true,"isPaused":false}'
        else
            ha_api_post "/services/vacuum/stop" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            resulting_state='{"on":false,"isRunning":false}'
        fi
    elif [ "$action" = "set_pause" ]; then
        local should_pause
        should_pause=$(printf '%s' "$payload_json" | jq -r '.pause // false')
        if [ "$should_pause" = "true" ]; then
            ha_api_post "/services/vacuum/pause" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            resulting_state='{"isPaused":true}'
        else
            ha_api_post "/services/vacuum/start" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            resulting_state='{"isPaused":false,"isRunning":true}'
        fi
    elif [ "$action" = "dock" ]; then
        ha_api_post "/services/vacuum/return_to_base" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
        resulting_state='{"isDocked":true,"isRunning":false}'
    elif [ "$action" = "locate" ]; then
        ha_api_post "/services/vacuum/locate" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
        resulting_state='{}'
    elif [ "$action" = "set_vacuum_fan_speed" ]; then
        local vac_fan_speed
        vac_fan_speed=$(printf '%s' "$payload_json" | jq -r '.fan_speed // ""')
        ha_api_post "/services/vacuum/set_fan_speed" "$(jq -n --arg entity_id "$entity_id" --arg fan_speed "$vac_fan_speed" '{entity_id: $entity_id, fan_speed: $fan_speed}')" >/dev/null || success=false
        resulting_state=$(jq -n --arg fs "$vac_fan_speed" '{fan_speed: $fs}')
    elif [ "$action" = "set_humidity" ]; then
        local target_humidity
        target_humidity=$(printf '%s' "$payload_json" | jq -r '.humidity // 50')
        ha_api_post "/services/humidifier/set_humidity" "$(jq -n --arg entity_id "$entity_id" --argjson humidity "$target_humidity" '{entity_id: $entity_id, humidity: $humidity}')" >/dev/null || success=false
        resulting_state=$(jq -n --argjson h "$target_humidity" '{target_humidity: $h}')
    elif [ "$action" = "set_humidifier_mode" ]; then
        local hum_mode
        hum_mode=$(printf '%s' "$payload_json" | jq -r '.mode // ""')
        ha_api_post "/services/humidifier/set_mode" "$(jq -n --arg entity_id "$entity_id" --arg mode "$hum_mode" '{entity_id: $entity_id, mode: $mode}')" >/dev/null || success=false
        resulting_state=$(jq -n --arg m "$hum_mode" '{mode: $m}')
    elif [ "$action" = "set_climate_fan_mode" ]; then
        local fan_mode
        fan_mode=$(printf '%s' "$payload_json" | jq -r '.fan_mode // ""')
        ha_api_post "/services/climate/set_fan_mode" "$(jq -n --arg entity_id "$entity_id" --arg fan_mode "$fan_mode" '{entity_id: $entity_id, fan_mode: $fan_mode}')" >/dev/null || success=false
        resulting_state=$(jq -n --arg m "$fan_mode" '{fan_mode: $m}')
    elif [ "$action" = "set_climate_preset_mode" ]; then
        local preset_mode
        preset_mode=$(printf '%s' "$payload_json" | jq -r '.preset_mode // ""')
        ha_api_post "/services/climate/set_preset_mode" "$(jq -n --arg entity_id "$entity_id" --arg preset_mode "$preset_mode" '{entity_id: $entity_id, preset_mode: $preset_mode}')" >/dev/null || success=false
        resulting_state=$(jq -n --arg m "$preset_mode" '{preset_mode: $m}')
    elif [ "$action" = "set_climate_swing_mode" ]; then
        local swing_mode
        swing_mode=$(printf '%s' "$payload_json" | jq -r '.swing_mode // ""')
        ha_api_post "/services/climate/set_swing_mode" "$(jq -n --arg entity_id "$entity_id" --arg swing_mode "$swing_mode" '{entity_id: $entity_id, swing_mode: $swing_mode}')" >/dev/null || success=false
        resulting_state=$(jq -n --arg m "$swing_mode" '{swing_mode: $m}')
    elif [ "$action" = "set_sound_mode" ]; then
        local sound_mode
        sound_mode=$(printf '%s' "$payload_json" | jq -r '.sound_mode // ""')
        ha_api_post "/services/media_player/select_sound_mode" "$(jq -n --arg entity_id "$entity_id" --arg sound_mode "$sound_mode" '{entity_id: $entity_id, sound_mode: $sound_mode}')" >/dev/null || success=false
        resulting_state=$(jq -n --arg m "$sound_mode" '{sound_mode: $m}')
    elif [ "$action" = "set_light_effect" ]; then
        local effect_name
        effect_name=$(printf '%s' "$payload_json" | jq -r '.effect // ""')
        ha_api_post "/services/light/turn_on" "$(jq -n --arg entity_id "$entity_id" --arg effect "$effect_name" '{entity_id: $entity_id, effect: $effect}')" >/dev/null || success=false
        resulting_state=$(jq -n --arg e "$effect_name" '{on: true, effect: $e}')
    elif [ "$action" = "arm_disarm" ]; then
        local arm_requested arm_level
        arm_requested=$(printf '%s' "$payload_json" | jq -r '.arm // false')
        arm_level=$(printf '%s' "$payload_json" | jq -r '.arm_level // ""')
        if [ "$arm_requested" = "true" ]; then
            case "$arm_level" in
                arm_home|home|L1)
                    ha_api_post "/services/alarm_control_panel/alarm_arm_home" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
                    resulting_state='{"arm_state":"armed_home"}'
                    ;;
                arm_away|away|L2)
                    ha_api_post "/services/alarm_control_panel/alarm_arm_away" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
                    resulting_state='{"arm_state":"armed_away"}'
                    ;;
                arm_night|night|L3)
                    ha_api_post "/services/alarm_control_panel/alarm_arm_night" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
                    resulting_state='{"arm_state":"armed_night"}'
                    ;;
                arm_custom_bypass|custom|L4)
                    ha_api_post "/services/alarm_control_panel/alarm_arm_custom_bypass" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
                    resulting_state='{"arm_state":"armed_custom_bypass"}'
                    ;;
                *)
                    ha_api_post "/services/alarm_control_panel/alarm_arm_home" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
                    resulting_state='{"arm_state":"armed_home"}'
                    ;;
            esac
        else
            ha_api_post "/services/alarm_control_panel/alarm_disarm" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            resulting_state='{"arm_state":"disarmed"}'
        fi
    elif [ "$action" = "set_water_heater_temperature" ]; then
        local wh_temp
        wh_temp=$(printf '%s' "$payload_json" | jq -r '.temperature // 50')
        ha_api_post "/services/water_heater/set_temperature" "$(jq -n --arg entity_id "$entity_id" --argjson temperature "$wh_temp" '{entity_id: $entity_id, temperature: $temperature}')" >/dev/null || success=false
        resulting_state=$(jq -n --argjson t "$wh_temp" '{target_temperature: $t}')
    elif [ "$action" = "get_camera_stream" ]; then
        local stream_path
        stream_path=$(python3 -c "
import json, os, sys
try:
    from websocket import create_connection
    token = os.environ.get('SUPERVISOR_TOKEN', '')
    entity_id = sys.argv[1]
    ws = create_connection('ws://supervisor/core/websocket', timeout=10)
    msg = json.loads(ws.recv())
    if msg.get('type') == 'auth_required':
        ws.send(json.dumps({'type': 'auth', 'access_token': token}))
    msg = json.loads(ws.recv())
    if msg.get('type') != 'auth_ok':
        sys.exit(1)
    ws.send(json.dumps({'id': 1, 'type': 'camera/stream', 'entity_id': entity_id}))
    msg = json.loads(ws.recv())
    ws.close()
    if msg.get('success') and msg.get('result', {}).get('url'):
        print(msg['result']['url'])
    else:
        sys.exit(1)
except Exception:
    sys.exit(1)
" "$entity_id" 2>/dev/null)
        if [ -n "$stream_path" ]; then
            resulting_state=$(jq -n --arg path "$stream_path" '{stream_path: $path}')
        else
            success=false
            error_msg="Unable to start camera stream"
        fi
    elif [ "$action" = "set_valve_position" ]; then
        local open_percent
        open_percent=$(printf '%s' "$payload_json" | jq -r '.openPercent // 0')
        ha_api_post "/services/valve/set_valve_position" "$(jq -n --arg entity_id "$entity_id" --argjson position "$open_percent" '{entity_id: $entity_id, position: $position}')" >/dev/null || success=false
        resulting_state=$(jq -n --argjson percent "$open_percent" '{openPercent: $percent}')
    elif [ "$action" = "set_valve_open_close" ]; then
        local open_direction
        open_direction=$(printf '%s' "$payload_json" | jq -r '.open // true')
        if [ "$open_direction" = "true" ]; then
            ha_api_post "/services/valve/open_valve" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            resulting_state='{"openPercent":100}'
        else
            ha_api_post "/services/valve/close_valve" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
            resulting_state='{"openPercent":0}'
        fi
    elif [ "$action" = "set_select_option" ]; then
        local selected_option
        selected_option=$(printf '%s' "$payload_json" | jq -r '.option // ""')
        if [ "$domain" = "input_select" ]; then
            ha_api_post "/services/input_select/select_option" "$(jq -n --arg entity_id "$entity_id" --arg option "$selected_option" '{entity_id: $entity_id, option: $option}')" >/dev/null || success=false
        else
            ha_api_post "/services/select/select_option" "$(jq -n --arg entity_id "$entity_id" --arg option "$selected_option" '{entity_id: $entity_id, option: $option}')" >/dev/null || success=false
        fi
        resulting_state=$(jq -n --arg opt "$selected_option" '{current_option: $opt}')
    elif [ "$action" = "lawn_mower_start" ]; then
        ha_api_post "/services/lawn_mower/start_mowing" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
        resulting_state='{"isRunning":true,"isPaused":false}'
    elif [ "$action" = "lawn_mower_pause" ]; then
        ha_api_post "/services/lawn_mower/pause" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
        resulting_state='{"isRunning":false,"isPaused":true}'
    elif [ "$action" = "lawn_mower_dock" ]; then
        ha_api_post "/services/lawn_mower/dock" "$(jq -n --arg entity_id "$entity_id" '{entity_id: $entity_id}')" >/dev/null || success=false
        resulting_state='{"isRunning":false,"isPaused":false,"isDocked":true}'
    else
        success=false
        error_msg="Unsupported action"
    fi

    if [ "$success" = "false" ] && [ -z "$error_msg" ]; then
        error_msg="Failed to apply command"
    fi

    local result_payload
    # Ensure resulting_state is valid JSON for --argjson
    if ! printf '%s' "$resulting_state" | jq -e '.' >/dev/null 2>&1; then
        resulting_state='{}'
    fi
    result_payload=$(jq -n \
        --argjson success "$success" \
        --arg error "$error_msg" \
        --argjson state "$resulting_state" \
        '{success: $success, error: ($error | if . == "" then null else . end), state: $state}' 2>/dev/null) || result_payload='{"success":false,"error":"result_payload_build_failed","state":{}}'

    local result_endpoint
    if [ "$channel" = "alexa" ]; then
        result_endpoint="/api/internal/devices/alexa/commands/${command_id}/result"
    else
        result_endpoint="/api/internal/devices/google-home/commands/${command_id}/result"
    fi
    cloud_post "$result_endpoint" "$result_payload" "$DEVICE_TOKEN" >/dev/null 2>/dev/null || true
}

sync_alexa_commands() {
    # Mirror of sync_google_commands for the Alexa channel. Reuses
    # execute_google_command with channel="alexa" so the HA dispatcher
    # logic stays DRY. Server has already translated Alexa directives into
    # Google-dialect actions before enqueueing.
    if [ "$FLEET_ACTIVE" -ne 1 ] || [ -z "$DEVICE_TOKEN" ]; then
        return
    fi

    local response
    response=$(cloud_post "/api/internal/devices/alexa/commands" '{}' "$DEVICE_TOKEN")
    if [ -z "$response" ]; then
        return
    fi

    while IFS= read -r command_item; do
        [ -z "$command_item" ] && continue
        execute_google_command "$command_item" "alexa"
    done < <(printf '%s' "$response" | jq -c '.commands[]?')
}

sync_google_commands() {
    if [ "$FLEET_ACTIVE" -ne 1 ] || [ -z "$DEVICE_TOKEN" ]; then
        return
    fi

    local response
    response=$(cloud_post "/api/internal/devices/google-home/commands" '{}' "$DEVICE_TOKEN")
    if [ -z "$response" ]; then
        return
    fi

    while IFS= read -r command_item; do
        [ -z "$command_item" ] && continue
        execute_google_command "$command_item"
    done < <(printf '%s' "$response" | jq -c '.commands[]?')
}

validate_google_sync_intervals() {
    case "$GOOGLE_ENTITY_SYNC_INTERVAL" in
        ''|*[!0-9]*)
            GOOGLE_ENTITY_SYNC_INTERVAL=5
            ;;
        *)
            if [ "$GOOGLE_ENTITY_SYNC_INTERVAL" -lt 1 ]; then
                GOOGLE_ENTITY_SYNC_INTERVAL=1
            fi
            ;;
    esac

    case "$GOOGLE_COMMAND_SYNC_INTERVAL" in
        ''|*[!0-9]*)
            GOOGLE_COMMAND_SYNC_INTERVAL=1
            ;;
        *)
            if [ "$GOOGLE_COMMAND_SYNC_INTERVAL" -lt 1 ]; then
                GOOGLE_COMMAND_SYNC_INTERVAL=1
            fi
            ;;
    esac

    case "$ALEXA_COMMAND_SYNC_INTERVAL" in
        ''|*[!0-9]*)
            ALEXA_COMMAND_SYNC_INTERVAL=1
            ;;
        *)
            if [ "$ALEXA_COMMAND_SYNC_INTERVAL" -lt 1 ]; then
                ALEXA_COMMAND_SYNC_INTERVAL=1
            fi
            ;;
    esac
}

start_google_sync_loop() {
    if [ "$FLEET_ACTIVE" -ne 1 ] || [ -z "$DEVICE_TOKEN" ]; then
        return
    fi

    (
        # Disable set -e inside sync loop: individual sync/command failures must NOT
        # kill the entire loop. Without this, any unprotected jq parse error, arithmetic
        # comparison with non-numeric input, or transient API failure causes the subshell
        # to exit permanently — stopping all entity syncs and command polling while the
        # heartbeat (separate subshell) keeps the device appearing online.
        set +e

        local entity_tick=0
        local entity_interval="$GOOGLE_ENTITY_SYNC_INTERVAL"
        if [ "$entity_interval" -lt 1 ]; then
            entity_interval=1
        fi

        while true; do
            if [ "$entity_tick" -le 0 ]; then
                sync_google_entities || bashio::log.warning "Google entity sync iteration failed (non-fatal, will retry)"
                entity_tick="$entity_interval"
            fi

            sync_google_commands || bashio::log.warning "Google command sync iteration failed (non-fatal, will retry)"
            sync_alexa_commands || bashio::log.warning "Alexa command sync iteration failed (non-fatal, will retry)"

            sleep "$GOOGLE_COMMAND_SYNC_INTERVAL"

            entity_tick=$((entity_tick - GOOGLE_COMMAND_SYNC_INTERVAL))
            if [ "$entity_tick" -lt 0 ]; then
                entity_tick=0
            fi
        done
    ) &

    GOOGLE_SYNC_PID=$!
}

save_device_token() {
    if [ -z "$DEVICE_TOKEN" ]; then
        return
    fi

    printf '%s' "$DEVICE_TOKEN" > "$DEVICE_TOKEN_PATH"
    chmod 600 "$DEVICE_TOKEN_PATH" || true
}

save_device_ssh_remote_port() {
    local remote_port="$1"
    printf '%s' "$remote_port" > "$DEVICE_SSH_REMOTE_PORT_PATH"
    chmod 600 "$DEVICE_SSH_REMOTE_PORT_PATH" || true
}

load_cached_device_ssh_remote_port() {
    if [ ! -f "$DEVICE_SSH_REMOTE_PORT_PATH" ]; then
        printf '0'
        return
    fi

    local cached_port
    cached_port=$(cat "$DEVICE_SSH_REMOTE_PORT_PATH" 2>/dev/null || true)

    if is_valid_port "$cached_port"; then
        printf '%s' "$cached_port"
        return
    fi

    printf '0'
}

send_device_log() {
    local level="$1"
    local event_type="$2"
    local message="$3"
    local payload_json="$4"

    if [ "$FLEET_ACTIVE" -ne 1 ] || [ -z "$DEVICE_TOKEN" ]; then
        return
    fi

    local payload
    if [ -n "$payload_json" ]; then
        payload=$(jq -n \
            --arg level "$level" \
            --arg event_type "$event_type" \
            --arg message "$message" \
            --argjson payload "$payload_json" \
            '{ level: $level, event_type: $event_type, message: $message, payload: $payload }')
    else
        payload=$(jq -n \
            --arg level "$level" \
            --arg event_type "$event_type" \
            --arg message "$message" \
            '{ level: $level, event_type: $event_type, message: $message }')
    fi

    cloud_post "/api/internal/devices/log" "$payload" "$DEVICE_TOKEN" >/dev/null
}

build_fleet_payload() {
    local state="$1"
    local local_ips_csv
    local local_ips_json='[]'
    local remote_port_json='null'

    local_ips_csv=$(get_local_ips_csv)

    if [ -n "$local_ips_csv" ]; then
        local_ips_json=$(jq -n --arg csv "$local_ips_csv" '$csv | split(",")')
    fi

    if [ "$SSH_REMOTE_PORT" -gt 0 ]; then
        remote_port_json="$SSH_REMOTE_PORT"
    fi

    jq -n \
        --arg access_token "$ACCESS_TOKEN" \
        --arg device_uid "$DEVICE_UID" \
        --arg device_name "$DEVICE_NAME" \
        --arg hostname "$DEVICE_HOSTNAME" \
        --argjson local_ips "$local_ips_json" \
        --argjson ssh_port "$SSH_LOCAL_PORT" \
        --arg remote_user "root" \
        --arg tunnel_host "$FRP_SERVER_ADDR" \
        --argjson tunnel_port "$remote_port_json" \
        --arg addon_version "apex-cloud-link" \
        --arg agent_state "$state" \
        '{
            access_token: $access_token,
            device_uid: $device_uid,
            device_name: $device_name,
            hostname: $hostname,
            local_ips: $local_ips,
            ssh_port: $ssh_port,
            remote_user: $remote_user,
            tunnel_host: $tunnel_host,
            tunnel_port: $tunnel_port,
            addon_version: $addon_version,
            agent_state: $agent_state
        }'
}

register_fleet_device() {
    if [ "$FLEET_ACTIVE" -ne 1 ]; then
        return
    fi

    local cached_token=''
    if [ -f "$DEVICE_TOKEN_PATH" ]; then
        cached_token=$(cat "$DEVICE_TOKEN_PATH" 2>/dev/null || true)
    fi

    local payload
    local response
    local next_interval
    local assigned_remote_port

    payload=$(build_fleet_payload "starting")
    response=$(cloud_post "/api/internal/devices/register" "$payload" "")

    if [ -n "$response" ]; then
        DEVICE_TOKEN=$(printf '%s' "$response" | jq --raw-output '.device_token // empty')
        next_interval=$(printf '%s' "$response" | jq --raw-output '.heartbeat_interval_seconds // empty')
        assigned_remote_port=$(printf '%s' "$response" | jq --raw-output '.data.tunnel_port // empty')

        case "$next_interval" in
            ''|*[!0-9]*)
                ;;
            *)
                HEARTBEAT_INTERVAL="$next_interval"
                ;;
        esac

        if is_valid_port "$assigned_remote_port"; then
            SSH_REMOTE_PORT="$assigned_remote_port"
            save_device_ssh_remote_port "$assigned_remote_port"
        fi
    fi

    if [ -z "$DEVICE_TOKEN" ] && [ -n "$cached_token" ]; then
        DEVICE_TOKEN="$cached_token"
        bashio::log.warning "Fleet registration unavailable, reusing cached device token."
    fi

    if [ -n "$DEVICE_TOKEN" ]; then
        save_device_token
        if [ "$SSH_REMOTE_PORT" -gt 0 ]; then
            bashio::log.info "Fleet reporting active for device uid=${DEVICE_UID}, ssh remote port=${SSH_REMOTE_PORT}"
        else
            bashio::log.warning "Fleet reporting active for device uid=${DEVICE_UID}, but no SSH remote port assigned yet"
        fi
    else
        bashio::log.warning "Fleet registration failed, continuing without heartbeat reporting."
        FLEET_ACTIVE=0
    fi
}

send_heartbeat() {
    local state="$1"

    if [ "$FLEET_ACTIVE" -ne 1 ] || [ -z "$DEVICE_TOKEN" ]; then
        return
    fi

    local payload
    local response
    local next_interval
    local assigned_remote_port

    payload=$(build_fleet_payload "$state")
    response=$(cloud_post "/api/internal/devices/heartbeat" "$payload" "$DEVICE_TOKEN")

    if [ -n "$response" ]; then
        next_interval=$(printf '%s' "$response" | jq --raw-output '.heartbeat_interval_seconds // empty')
        assigned_remote_port=$(printf '%s' "$response" | jq --raw-output '.data.tunnel_port // empty')
        case "$next_interval" in
            ''|*[!0-9]*)
                ;;
            *)
                HEARTBEAT_INTERVAL="$next_interval"
                ;;
        esac

        if is_valid_port "$assigned_remote_port"; then
            SSH_REMOTE_PORT="$assigned_remote_port"
            save_device_ssh_remote_port "$assigned_remote_port"
        fi
    fi
}

start_heartbeat_loop() {
    if [ "$FLEET_ACTIVE" -ne 1 ] || [ -z "$DEVICE_TOKEN" ]; then
        return
    fi

    (
        set +e
        while true; do
            send_heartbeat "running" || bashio::log.warning "Heartbeat send failed (non-fatal, will retry)"
            sleep "$HEARTBEAT_INTERVAL"
        done
    ) &

    HEARTBEAT_PID=$!
}

cleanup() {
    if [ -n "$GOOGLE_SYNC_PID" ]; then
        kill "$GOOGLE_SYNC_PID" 2>/dev/null || true
        wait "$GOOGLE_SYNC_PID" 2>/dev/null || true
    fi

    if [ -n "$HEARTBEAT_PID" ]; then
        kill "$HEARTBEAT_PID" 2>/dev/null || true
        wait "$HEARTBEAT_PID" 2>/dev/null || true
    fi

    if [ "$FLEET_ACTIVE" -eq 1 ] && [ -n "$DEVICE_TOKEN" ]; then
        send_device_log "warn" "device.shutdown" "Cloud Link service stopped" ""
        send_heartbeat "stopped"
    fi
}

trap cleanup EXIT INT TERM

if [ -z "$SUBDOMAIN" ] || [ -z "$ACCESS_TOKEN" ]; then
    bashio::log.error "Subdomain or Access Token is missing"
    bashio::log.error "Please register in Cloud Connect and configure the addon options"
    sleep infinity
fi

if [ -z "$CLOUD_API_URL" ]; then
    bashio::log.error "Cloud API URL is empty"
    sleep infinity
fi

if ! [[ "$SUBDOMAIN" =~ ^[a-z0-9-]{3,20}$ ]]; then
    bashio::log.error "Invalid subdomain format. Use 3-20 lowercase letters, digits, or hyphen"
    sleep infinity
fi

DEVICE_HOSTNAME=$(hostname 2>/dev/null || echo "unknown-device")
DEVICE_UID="cloudlink-$(sanitize_uid "$DEVICE_HOSTNAME")-${SUBDOMAIN}"
DEVICE_NAME="$DEVICE_HOSTNAME"
FLEET_ACTIVE=1
SSH_REMOTE_PORT=$(load_cached_device_ssh_remote_port)

if [ -z "$DEVICE_UID" ]; then
    DEVICE_UID="cloudlink-$(sanitize_uid "$DEVICE_HOSTNAME")-${SUBDOMAIN}"
fi

if [ -z "$DEVICE_NAME" ]; then
    DEVICE_NAME="$DEVICE_HOSTNAME"
fi

validate_google_sync_intervals

bashio::log.info "Initializing Cloud Link for ${SUBDOMAIN}.cloud.apexinfosys.in"

ARCH=$(bashio::info.arch)
FRP_ARCH=""

case $ARCH in
    aarch64) FRP_ARCH="arm64" ;;
    amd64) FRP_ARCH="amd64" ;;
    armhf|armv7) FRP_ARCH="arm" ;;
    i386) FRP_ARCH="386" ;;
    *)
        bashio::log.error "Unsupported architecture: $ARCH"
        sleep infinity
        ;;
esac

if [ -f "$FRPC_BIN" ]; then
    CURRENT_VERSION=$("$FRPC_BIN" -v 2>/dev/null || echo "0")
    if [ "$CURRENT_VERSION" != "$FRP_VERSION" ]; then
        bashio::log.info "FRP version mismatch (${CURRENT_VERSION} vs ${FRP_VERSION}), downloading update"
        rm -f "$FRPC_BIN"
    fi
fi

if [ ! -f "$FRPC_BIN" ]; then
    bashio::log.info "Downloading FRP client for ${FRP_ARCH}"
    mkdir -p "$FRP_DIR"

    wget -qO /tmp/frp.tar.gz "https://github.com/fatedier/frp/releases/download/v${FRP_VERSION}/frp_${FRP_VERSION}_linux_${FRP_ARCH}.tar.gz"
    tar -xzf /tmp/frp.tar.gz -C /tmp/
    mv "/tmp/frp_${FRP_VERSION}_linux_${FRP_ARCH}/frpc" "$FRPC_BIN"
    chmod +x "$FRPC_BIN"

    rm -rf /tmp/frp*
    bashio::log.info "FRP client download complete"
fi

if [ "$FLEET_ACTIVE" -eq 1 ]; then
    register_fleet_device
fi

cat << TOML_EOF > "$FRPC_CONFIG"
serverAddr = "${FRP_SERVER_ADDR}"
serverPort = ${FRP_SERVER_PORT}

loginFailExit = false

auth.method = "token"
auth.token = "apexcloud_transport_v1"

[metadatas]
token = "${ACCESS_TOKEN}"

[[proxies]]
name = "apex_web_${SUBDOMAIN}"
type = "http"
localIP = "127.0.0.1"
localPort = 1702
customDomains = ["${SUBDOMAIN}.cloud.apexinfosys.in"]
TOML_EOF

if [ "$SSH_REMOTE_PORT" -gt 0 ]; then
    cat << TOML_SSH_EOF >> "$FRPC_CONFIG"

[[proxies]]
name = "apex_ssh_${SUBDOMAIN}"
type = "tcp"
localIP = "127.0.0.1"
localPort = ${SSH_LOCAL_PORT}
remotePort = ${SSH_REMOTE_PORT}
TOML_SSH_EOF

    bashio::log.info "SSH TCP proxy enabled on ${FRP_SERVER_ADDR}:${SSH_REMOTE_PORT}"
else
    bashio::log.warning "SSH TCP proxy skipped because no remote port is assigned yet"
fi

if [ "$FLEET_ACTIVE" -eq 1 ] && [ -n "$DEVICE_TOKEN" ]; then
    send_device_log "info" "device.start" "Cloud Link service starting" "$(jq -n --arg subdomain "$SUBDOMAIN" --arg frp_addr "$FRP_SERVER_ADDR" --arg frp_port "$FRP_SERVER_PORT" --arg ssh_remote_port "$SSH_REMOTE_PORT" '{subdomain: $subdomain, frp_addr: $frp_addr, frp_port: $frp_port, ssh_remote_port: $ssh_remote_port}')"
    send_heartbeat "starting"
    # Initial entity sync with retry — HA Core may not be fully ready at addon start
    sync_google_entities || bashio::log.warning "Initial entity sync failed (non-fatal, sync loop will retry)"
    if [ "$GOOGLE_WARNED_EMPTY_ENTITY_SYNC" -eq 1 ]; then
        bashio::log.info "Retrying initial entity sync in 5s..."
        sleep 5
        GOOGLE_WARNED_EMPTY_ENTITY_SYNC=0
        sync_google_entities || bashio::log.warning "Initial entity sync retry also failed (non-fatal)"
    fi
    sync_google_commands || true
    sync_alexa_commands || true
    start_heartbeat_loop
    start_google_sync_loop
fi

bashio::log.info "Configuration generated. Connecting to cloud"

set +e
"$FRPC_BIN" -c "$FRPC_CONFIG"
FRPC_EXIT_CODE=$?
set -e

if [ "$FRPC_EXIT_CODE" -eq 0 ]; then
    send_device_log "warn" "frpc.exit" "FRPC process exited cleanly" "$(jq -n --arg code "$FRPC_EXIT_CODE" '{exit_code: $code}')"
else
    send_device_log "error" "frpc.exit" "FRPC process exited with error" "$(jq -n --arg code "$FRPC_EXIT_CODE" '{exit_code: $code}')"
fi

exit "$FRPC_EXIT_CODE"
