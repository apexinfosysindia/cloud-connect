# ----------------------------------------------------
# FRP Server (FRPS) Configuration
# ----------------------------------------------------
# Copy this to frps.toml and fill in real values, OR
# set FRPS_AUTH_TOKEN and FRPS_DASHBOARD_PASSWORD as
# environment variables — the deploy workflow generates
# frps.toml from this template via envsubst.
# ----------------------------------------------------

bindPort = 7000
vhostHTTPPort = 8080
proxyBindAddr = "127.0.0.1"
custom404Page = "/etc/frp/custom_404.html"

transport.tcpMux = true

# Optional Dashboard
webServer.port = 7500
webServer.user = "admin"
webServer.password = "${FRPS_DASHBOARD_PASSWORD}"

# ----------------------------------------------------
# Authentication & Webhook
# ----------------------------------------------------
# Shared FRP auth token for transport-level login.
# User-level authorization still happens in the webhook using metas.token.
auth.method = "token"
auth.token = "${FRPS_AUTH_TOKEN}"

[[httpPlugins]]
name = "user-auth"
addr = "127.0.0.1:3000"
path = "/api/internal/verify-token"
ops = ["Login", "Ping", "NewWorkConn", "NewUserConn"]
